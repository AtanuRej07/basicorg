<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="editEmployeeDialog"
        title="Edit Employee">

        <content>

            <VBox class="sapUiMediumMargin">

                <Input
                    value="{edit>/name}"/>

                <Input
                    value="{edit>/title}"/>

                <Input
                    value="{edit>/department}"/>

                <Input
                    value="{edit>/email}"/>

                <Input
                    value="{edit>/phone}"/>

            </VBox>

        </content>

        <beginButton>

            <Button
                text="Update"
                type="Emphasized"
                press=".onEditSubmit"/>

        </beginButton>

        <endButton>

            <Button
                text="Cancel"
                press=".onCloseEditDialog"/>

        </endButton>

    </Dialog>

</core:FragmentDefinition>