<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">

    <Dialog
        id="addEmployeeDialog"
        title="Add Employee">

        <content>

            <VBox class="sapUiMediumMargin">

                <Input
                    id="addName"
                    placeholder="Employee Name"/>

                <Input
                    id="addTitle"
                    placeholder="Position"/>

                <Input
                    id="addDepartment"
                    placeholder="Department"/>

                <Input
                    id="addEmail"
                    placeholder="Email"/>

                <Input
                    id="addPhone"
                    placeholder="Phone"/>

            </VBox>

        </content>

        <beginButton>

            <Button
                text="Submit"
                type="Emphasized"
                press=".onAddSubmit"/>

        </beginButton>

        <endButton>

            <Button
                text="Cancel"
                press=".onCloseAddDialog"/>

        </endButton>

    </Dialog>

</core:FragmentDefinition>